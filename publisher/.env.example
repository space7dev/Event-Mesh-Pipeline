# SAP Event Mesh service key values (from BTP cockpit → Event Mesh → Service Key)
EM_TOKEN_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com/oauth/token
EM_CLIENT_ID=sb-clone-<uuid>!<id>
EM_CLIENT_SECRET=<secret>
EM_BASE_URL=https://enterprise-messaging-pubsub.cfapps.<region>.hana.ondemand.com

# Tenant identifier — must appear in every topic path
TENANT_ID=tenant001

# Shared secret for HMAC-SHA256 body signing (same value configured in CPI iFlow)
HMAC_SECRET=change-me-super-secret-32-chars-min

# For bad-sink demo: URL that returns 5xx to trigger DLQ path
SINK_URL=https://your-consumer.cfapps.<region>.hana.ondemand.com/events/discovery
